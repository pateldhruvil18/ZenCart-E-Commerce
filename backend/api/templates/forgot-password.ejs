<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Password Reset - E-Commerce Store</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f9fafb; font-family: Arial, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding: 48px 16px;">
        <table width="480" cellpadding="0" cellspacing="0" style="background: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden;">
          <!-- Header -->
          <tr>
            <td style="background: #111827; padding: 24px 32px;">
              <h1 style="margin: 0; color: #ffffff; font-size: 20px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase;">E-Commerce Store</h1>
            </td>
          </tr>
          <!-- Body -->
          <tr>
            <td style="padding: 32px;">
              <h2 style="margin: 0 0 8px 0; font-size: 22px; color: #111827;">Password Reset Request</h2>
              <p style="color: #6b7280; font-size: 15px; margin: 0 0 28px 0; line-height: 1.6;">
                We received a request to reset the password for your account.
                Use the OTP below to set a new password.
              </p>

              <!-- OTP Box -->
              <div style="background: #f3f4f6; border-radius: 10px; padding: 24px 32px; text-align: center; margin-bottom: 28px;">
                <p style="margin: 0 0 8px 0; font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 2px;">Password Reset Code</p>
                <span style="font-size: 42px; font-weight: 800; letter-spacing: 14px; color: #111827; display: block;"><%= otp %></span>
              </div>

              <p style="color: #9ca3af; font-size: 13px; margin: 0; line-height: 1.6;">
                This code is valid for <strong style="color: #6b7280;">10 minutes</strong>.
                If you did not request a password reset, please ignore this email.
                Your account remains secure.
              </p>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="background: #f9fafb; padding: 20px 32px; border-top: 1px solid #e5e7eb;">
              <p style="margin: 0; font-size: 12px; color: #9ca3af; text-align: center;">
                &copy; <%= new Date().getFullYear() %> E-Commerce Store. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
